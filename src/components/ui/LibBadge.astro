---
interface Props {
  label: string;
  version?: string;
}

const { label, version } = Astro.props;
---

<span
  class="bg-secondary text-secondary-foreground inline-flex items-center gap-2 rounded-lg px-3 py-1.5 font-mono text-sm"
>
  {label}
  {version && <span class="bg-primary/10 text-primary rounded-full px-2 py-0.5 text-xs">{version}</span>}
</span>
