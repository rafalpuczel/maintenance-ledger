---
import { FileText, ChevronDown, Menu, LogOut } from "lucide-react";

// Current path drives aria-current; passed from AppShell (Astro.url.pathname).
interface Props {
  pathname: string;
}
const { pathname } = Astro.props;

const settingsPaths = ["/brand-settings", "/plugins-catalog", "/pm-contacts"];
const isActive = (href: string) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
const settingsActive = settingsPaths.some((p) => pathname.startsWith(p));

const navLink =
  "rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground hover:bg-accent aria-[current=page]:text-foreground aria-[current=page]:bg-accent";
---

<header class="border-border bg-card/95 sticky top-0 z-40 border-b backdrop-blur">
  <nav aria-label="Main" class="mx-auto flex h-14 max-w-6xl items-center justify-between gap-4 px-4 sm:px-6">
    <!-- Brand / home -->
    <a
      href="/"
      class="text-foreground flex items-center gap-2 font-semibold"
      aria-current={pathname === "/" ? "page" : undefined}
    >
      <FileText className="text-primary size-5" />
      <span>Maintenance Ledger</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-1 md:flex">
      <a href="/" class:list={navLink} aria-current={pathname === "/" ? "page" : undefined}>Dashboard</a>
      <a href="/projects" class:list={navLink} aria-current={isActive("/projects") ? "page" : undefined}>Projects</a>

      <!-- Settings dropdown (keyboard-operable native disclosure) -->
      <details class="group relative">
        <summary
          class:list={[navLink, "flex cursor-pointer list-none items-center gap-1 [&::-webkit-details-marker]:hidden"]}
          aria-current={settingsActive ? "page" : undefined}
        >
          Settings
          <ChevronDown className="size-4 transition-transform group-open:rotate-180" />
        </summary>
        <div
          class="border-border bg-popover absolute right-0 mt-1 w-48 overflow-hidden rounded-lg border py-1 shadow-md"
        >
          <a
            href="/brand-settings"
            class="text-popover-foreground hover:bg-accent block px-3 py-2 text-sm"
            aria-current={pathname.startsWith("/brand-settings") ? "page" : undefined}>Brand settings</a
          >
          <a
            href="/plugins-catalog"
            class="text-popover-foreground hover:bg-accent block px-3 py-2 text-sm"
            aria-current={pathname.startsWith("/plugins-catalog") ? "page" : undefined}>Plugins catalog</a
          >
          <a
            href="/pm-contacts"
            class="text-popover-foreground hover:bg-accent block px-3 py-2 text-sm"
            aria-current={pathname.startsWith("/pm-contacts") ? "page" : undefined}>PM contacts</a
          >
        </div>
      </details>

      <form method="POST" action="/api/auth/logout" class="ml-1">
        <button type="submit" class:list={[navLink, "flex items-center gap-1.5"]}>
          <LogOut className="size-4" />
          Sign out
        </button>
      </form>
    </div>

    <!-- Mobile menu (keyboard-operable native disclosure) -->
    <details class="group relative md:hidden">
      <summary
        class="text-foreground hover:bg-accent flex cursor-pointer list-none items-center rounded-md p-2 [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <Menu className="size-5" />
      </summary>
      <div class="border-border bg-popover absolute right-0 mt-1 w-56 overflow-hidden rounded-lg border py-1 shadow-md">
        <a
          href="/"
          class="text-popover-foreground hover:bg-accent block px-4 py-2.5 text-sm"
          aria-current={pathname === "/" ? "page" : undefined}>Dashboard</a
        >
        <a
          href="/projects"
          class="text-popover-foreground hover:bg-accent block px-4 py-2.5 text-sm"
          aria-current={isActive("/projects") ? "page" : undefined}>Projects</a
        >
        <div class="border-border my-1 border-t"></div>
        <p class="text-muted-foreground px-4 pt-1 pb-1 text-xs font-semibold tracking-wide uppercase">Settings</p>
        <a
          href="/brand-settings"
          class="text-popover-foreground hover:bg-accent block px-4 py-2.5 text-sm"
          aria-current={pathname.startsWith("/brand-settings") ? "page" : undefined}>Brand settings</a
        >
        <a
          href="/plugins-catalog"
          class="text-popover-foreground hover:bg-accent block px-4 py-2.5 text-sm"
          aria-current={pathname.startsWith("/plugins-catalog") ? "page" : undefined}>Plugins catalog</a
        >
        <a
          href="/pm-contacts"
          class="text-popover-foreground hover:bg-accent block px-4 py-2.5 text-sm"
          aria-current={pathname.startsWith("/pm-contacts") ? "page" : undefined}>PM contacts</a
        >
        <div class="border-border my-1 border-t"></div>
        <form method="POST" action="/api/auth/logout">
          <button
            type="submit"
            class="text-popover-foreground hover:bg-accent flex w-full items-center gap-1.5 px-4 py-2.5 text-left text-sm"
          >
            <LogOut className="size-4" />
            Sign out
          </button>
        </form>
      </div>
    </details>
  </nav>
</header>
