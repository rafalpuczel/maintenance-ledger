---
import AppShell from "@/layouts/AppShell.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import ProjectForm from "@/components/projects/ProjectForm";
import DeleteProjectButton from "@/components/projects/DeleteProjectButton";
import RecurringPlugins from "@/components/project-recurring-plugins/RecurringPlugins";
import NewReportButton from "@/components/reports/NewReportButton";
import { ArrowLeft } from "lucide-react";
import { createSupabaseClient } from "@/lib/supabase";
import { getProjectBySlug } from "@/lib/projects/queries";
import { listCatalog } from "@/lib/plugins-catalog/queries";
import { listRecurringPlugins } from "@/lib/project-recurring-plugins/queries";
import { listReportsByProject } from "@/lib/reports/queries";

const slug = Astro.params.slug ?? "";
const client = createSupabaseClient();
const project = await getProjectBySlug(client, slug);

if (!project) {
  return Astro.redirect("/projects");
}

const [recurring, catalog, reports] = await Promise.all([
  listRecurringPlugins(client, project.id),
  listCatalog(client),
  listReportsByProject(client, project.id),
]);
---

<AppShell title={project.name}>
  <div class="mx-auto max-w-2xl">
    <div class="mb-6 flex items-center justify-between gap-4">
      <a
        href="/projects"
        class="text-muted-foreground hover:text-foreground inline-flex items-center gap-1 text-sm underline-offset-4 hover:underline"
      >
        <ArrowLeft className="size-4" />
        Projects
      </a>
      <DeleteProjectButton projectId={project.id} projectName={project.name} slug={project.slug} client:load />
    </div>

    <div class="border-border bg-card rounded-xl border p-8 shadow-sm">
      <h1 class="mb-6 text-2xl font-bold tracking-tight">{project.name}</h1>
      <ProjectForm
        action={`/api/projects/${project.id}`}
        mode="edit"
        initial={{
          name: project.name,
          slug: project.slug,
          url: project.url ?? "",
          contact_company: project.contact_company ?? "",
          contact_name: project.contact_name ?? "",
          contact_email: project.contact_email ?? "",
          internal_notes: project.internal_notes ?? "",
        }}
        client:load
      />
    </div>

    <section class="mt-8">
      <h2 class="mb-1 text-lg font-semibold">Recurring plugins</h2>
      <p class="text-muted-foreground mb-4 text-sm">
        These plugins pre-fill every new report for this project. Pick from the catalog or add a new name.
      </p>
      <RecurringPlugins
        projectId={project.id}
        slug={project.slug}
        recurring={recurring}
        catalog={catalog.map((c) => ({ id: c.id, name: c.name }))}
        client:load
      />
    </section>

    <section class="mt-8">
      <div class="mb-4 flex items-center justify-between gap-4">
        <div>
          <h2 class="text-lg font-semibold">Reports</h2>
          <p class="text-muted-foreground text-sm">Maintenance reports for this project, newest first.</p>
        </div>
        <NewReportButton projectId={project.id} slug={project.slug} client:load />
      </div>

      {
        reports.length === 0 ? (
          <EmptyState title="No reports yet" description="Create the first report for this project." />
        ) : (
          <ul class="space-y-2">
            {reports.map((report) => (
              <li>
                <a
                  href={`/projects/${project.slug}/reports/${report.id}`}
                  class="border-border bg-card hover:bg-accent flex items-center justify-between gap-3 rounded-lg border px-4 py-3 shadow-xs transition-colors"
                >
                  <span class="text-foreground font-medium">{report.month}</span>
                  <span class="text-muted-foreground text-sm">{new Date(report.created_at).toLocaleDateString()}</span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </div>
</AppShell>
