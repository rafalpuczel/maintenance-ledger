---
import AppShell from "@/layouts/AppShell.astro";
import ProjectForm from "@/components/projects/ProjectForm";
import { ArrowLeft } from "lucide-react";

const error = Astro.url.searchParams.get("error");
---

<AppShell title="New project">
  <div class="mx-auto max-w-xl">
    <a
      href="/projects"
      class="text-muted-foreground hover:text-foreground mb-4 inline-flex items-center gap-1 text-sm underline-offset-4 hover:underline"
    >
      <ArrowLeft className="size-4" />
      Projects
    </a>
    <div class="border-border bg-card rounded-xl border p-8 shadow-sm">
      <h1 class="mb-6 text-2xl font-bold tracking-tight">New project</h1>
      <ProjectForm action="/api/projects" mode="create" serverError={error} client:load />
    </div>
  </div>
</AppShell>
