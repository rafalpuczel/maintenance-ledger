---
import AppShell from "@/layouts/AppShell.astro";
import Banner from "@/components/ui/Banner.astro";
import DeleteReportButton from "@/components/reports/DeleteReportButton";
import ReportForm from "@/components/reports/ReportForm";
import SendToClientButton from "@/components/reports/SendToClientButton";
import SendToPmButton from "@/components/reports/SendToPmButton";
import { ArrowLeft, FileText, Users, Mail } from "lucide-react";
import { createSupabaseClient } from "@/lib/supabase";
import { getProjectBySlug } from "@/lib/projects/queries";
import { listCatalog } from "@/lib/plugins-catalog/queries";
import { listContacts } from "@/lib/pm-contacts/queries";
import { getReport } from "@/lib/reports/queries";
import { getSendSummary } from "@/lib/report-sends/queries";

const slug = Astro.params.slug ?? "";
const id = Astro.params.id ?? "";
const client = createSupabaseClient();

const [project, report, catalog, contacts, sends] = await Promise.all([
  getProjectBySlug(client, slug),
  getReport(client, id),
  listCatalog(client),
  listContacts(client),
  getSendSummary(client, id),
]);

if (!project) {
  return Astro.redirect("/projects?error=Project%20not%20found");
}
if (!report) {
  return Astro.redirect(`/projects/${slug}?error=Report%20not%20found`);
}

const error = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");
const okMessage =
  ok === "created"
    ? "Report created."
    : ok === "saved"
      ? "Changes saved."
      : ok === "sent-pm"
        ? "Report sent to the PM."
        : ok === "sent-client"
          ? "Report sent to the client."
          : null;

// Catalog names feed the plugin-row datalist combobox in the form.
const catalogNames = catalog.map((c) => c.name);
---

<AppShell title={`${project.name} — ${report.month}`}>
  <div class="mx-auto max-w-2xl">
    <a
      href={`/projects/${project.slug}`}
      class="text-muted-foreground hover:text-foreground mb-4 inline-flex items-center gap-1 text-sm underline-offset-4 hover:underline"
    >
      <ArrowLeft className="size-4" />
      {project.name}
    </a>

    <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold tracking-tight">Report — {report.month}</h1>
        <p class="text-muted-foreground text-sm">{project.name}</p>
      </div>
      <div class="flex flex-wrap items-center justify-end gap-2">
        <a
          href={`/api/reports/${report.id}/pdf`}
          target="_blank"
          rel="noopener"
          class="border-input bg-card hover:bg-accent hover:text-accent-foreground inline-flex h-9 items-center gap-2 rounded-md border px-4 text-sm font-medium shadow-xs transition-colors"
        >
          <FileText className="size-4" />
          View PDF
        </a>
        <SendToPmButton
          reportId={report.id}
          slug={project.slug}
          contacts={contacts.map((c) => ({ id: c.id, name: c.name, email: c.email }))}
          lastSend={sends.pm}
          client:load
        />
        <SendToClientButton
          reportId={report.id}
          slug={project.slug}
          clientEmail={project.contact_email}
          lastSend={sends.client}
          client:load
        />
        <DeleteReportButton reportId={report.id} slug={project.slug} client:load />
      </div>
    </div>

    {/* Delivery status — send history for both recipients, out of the button row */}
    <div class="border-border bg-border mb-6 grid grid-cols-1 gap-px overflow-hidden rounded-lg border sm:grid-cols-2">
      <div class="bg-card flex items-center gap-2 px-4 py-2.5 text-sm">
        <Users className="text-muted-foreground size-4 shrink-0" />
        <span class="text-muted-foreground">PM:</span>
        {
          sends.pm ? (
            <span class="text-foreground truncate">
              {sends.pm.email}
              <span class="text-muted-foreground"> · {new Date(sends.pm.sentAt).toLocaleDateString()}</span>
            </span>
          ) : (
            <span class="text-muted-foreground">Not sent yet</span>
          )
        }
      </div>
      <div class="bg-card flex items-center gap-2 px-4 py-2.5 text-sm">
        <Mail className="text-muted-foreground size-4 shrink-0" />
        <span class="text-muted-foreground">Client:</span>
        {
          sends.client ? (
            <span class="text-foreground truncate">
              {sends.client.email}
              <span class="text-muted-foreground"> · {new Date(sends.client.sentAt).toLocaleDateString()}</span>
            </span>
          ) : (
            <span class="text-muted-foreground">Not sent yet</span>
          )
        }
      </div>
    </div>

    {okMessage && <Banner variant="success" message={okMessage} />}

    <ReportForm
      action={`/api/reports/${report.id}`}
      slug={project.slug}
      month={report.month}
      catalogNames={catalogNames}
      serverError={error}
      initial={{
        wp_core_version: report.wp_core_version,
        wp_core_updated: report.wp_core_updated,
        php_updated: report.php_updated,
        php_from_version: report.php_from_version,
        php_to_version: report.php_to_version,
        integrity_status: report.integrity_status,
        integrity_issues: report.integrity_issues,
        fixes_applied: report.fixes_applied,
        notes_to_client: report.notes_to_client,
        plugins: report.plugins,
        themes: report.themes,
        licenses: report.licenses,
      }}
      client:load
    />
  </div>
</AppShell>
