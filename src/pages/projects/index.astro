---
import AppShell from "@/layouts/AppShell.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import { FolderPlus } from "lucide-react";
import { createSupabaseClient } from "@/lib/supabase";
import { listProjects } from "@/lib/projects/queries";

const projects = await listProjects(createSupabaseClient());
---

<AppShell title="Projects">
  <div class="mb-6 flex items-center justify-between gap-4">
    <h1 class="text-2xl font-bold tracking-tight">Projects</h1>
    <a
      href="/projects/new"
      class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center gap-2 rounded-md px-4 text-sm font-medium transition-colors"
    >
      <FolderPlus className="size-4" />
      New project
    </a>
  </div>

  {
    projects.length === 0 ? (
      <EmptyState title="No projects yet" description="Create your first project to start authoring reports.">
        <a href="/projects/new" class="text-primary text-sm underline-offset-4 hover:underline">
          Create your first project
        </a>
      </EmptyState>
    ) : (
      <ul class="space-y-2">
        {projects.map((p) => (
          <li>
            <a
              href={`/projects/${p.slug}`}
              class="border-border bg-card hover:bg-accent flex items-center justify-between rounded-lg border px-4 py-3 shadow-xs transition-colors"
            >
              <span>
                <span class="text-foreground font-medium">{p.name}</span>
                <span class="text-muted-foreground ml-2 text-sm">{p.slug}</span>
              </span>
              {p.contact_company && <span class="text-muted-foreground text-sm">{p.contact_company}</span>}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</AppShell>
