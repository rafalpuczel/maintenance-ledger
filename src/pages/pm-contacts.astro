---
import AppShell from "@/layouts/AppShell.astro";
import Banner from "@/components/ui/Banner.astro";
import PmContacts from "@/components/pm-contacts/PmContacts";
import { createSupabaseClient } from "@/lib/supabase";
import { listContacts } from "@/lib/pm-contacts/queries";

const entries = await listContacts(createSupabaseClient());

const error = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");
const okMessage =
  ok === "created"
    ? "Contact added."
    : ok === "updated"
      ? "Changes saved."
      : ok === "deleted"
        ? "Contact removed."
        : null;
---

<AppShell title="PM contacts">
  <div class="mx-auto max-w-2xl">
    <div class="mb-6">
      <h1 class="text-2xl font-bold tracking-tight">PM contacts</h1>
      <p class="text-muted-foreground mt-1 text-sm">
        The people you send reports to. Add a name and email for each PM so they’re available in the “Send to PM”
        picker.
      </p>
    </div>

    {okMessage && <Banner variant="success" message={okMessage} />}

    <PmContacts
      entries={entries.map((e) => ({ id: e.id, name: e.name, email: e.email }))}
      serverError={error}
      client:load
    />
  </div>
</AppShell>
