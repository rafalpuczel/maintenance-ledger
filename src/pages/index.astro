---
import AppShell from "@/layouts/AppShell.astro";
import EmptyState from "@/components/ui/EmptyState.astro";
import { FolderPlus, FolderOpen, FileText, Settings } from "lucide-react";
import { createSupabaseClient } from "@/lib/supabase";
import { listProjects } from "@/lib/projects/queries";
import { listRecentReports } from "@/lib/reports/queries";

const client = createSupabaseClient();
const [projects, recentReports] = await Promise.all([listProjects(client), listRecentReports(client, 5)]);

const recentProjects = projects.slice(0, 5);
const isEmpty = projects.length === 0 && recentReports.length === 0;

const cardClass = "rounded-xl border border-border bg-card p-5 shadow-sm";
const rowClass =
  "flex items-center justify-between gap-3 rounded-lg border border-border px-4 py-3 text-sm transition-colors hover:bg-accent";
---

<AppShell title="Dashboard">
  <div class="mb-8">
    <h1 class="text-2xl font-bold tracking-tight">Dashboard</h1>
    <p class="text-muted-foreground mt-1 text-sm">Your maintenance reporting at a glance.</p>
  </div>

  {/* Quick actions */}
  <div class="mb-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
    <a href="/projects/new" class:list={[cardClass, "hover:border-primary/40 flex items-center gap-3"]}>
      <FolderPlus className="text-primary size-5" />
      <span class="font-medium">New project</span>
    </a>
    <a href="/projects" class:list={[cardClass, "hover:border-primary/40 flex items-center gap-3"]}>
      <FolderOpen className="text-primary size-5" />
      <span class="font-medium">All projects</span>
    </a>
    <a href="/brand-settings" class:list={[cardClass, "hover:border-primary/40 flex items-center gap-3"]}>
      <Settings className="text-primary size-5" />
      <span class="font-medium">Brand settings</span>
    </a>
    <a href="/pm-contacts" class:list={[cardClass, "hover:border-primary/40 flex items-center gap-3"]}>
      <FileText className="text-primary size-5" />
      <span class="font-medium">PM contacts</span>
    </a>
  </div>

  {
    isEmpty ? (
      <EmptyState
        title="No projects yet"
        description="Create your first project to start authoring maintenance reports."
      >
        <FolderPlus slot="icon" className="mb-3 size-8 text-muted-foreground" />
        <a
          href="/projects/new"
          class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex h-9 items-center gap-2 rounded-md px-4 text-sm font-medium transition-colors"
        >
          <FolderPlus className="size-4" />
          New project
        </a>
      </EmptyState>
    ) : (
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        {/* Recent projects */}
        <section>
          <div class="mb-3 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Recent projects</h2>
            <a href="/projects" class="text-primary text-sm underline-offset-4 hover:underline">
              View all
            </a>
          </div>
          {recentProjects.length === 0 ? (
            <EmptyState title="No projects yet" description="Create a project to get started." />
          ) : (
            <ul class="space-y-2">
              {recentProjects.map((p) => (
                <li>
                  <a href={`/projects/${p.slug}`} class:list={rowClass}>
                    <span>
                      <span class="text-foreground font-medium">{p.name}</span>
                      <span class="text-muted-foreground ml-2">{p.slug}</span>
                    </span>
                    {p.contact_company && <span class="text-muted-foreground">{p.contact_company}</span>}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>

        {/* Recent reports */}
        <section>
          <div class="mb-3 flex items-center justify-between">
            <h2 class="text-lg font-semibold">Recent reports</h2>
          </div>
          {recentReports.length === 0 ? (
            <EmptyState title="No reports yet" description="Open a project and create its first report." />
          ) : (
            <ul class="space-y-2">
              {recentReports.map((r) => (
                <li>
                  <a href={`/projects/${r.project_slug}/reports/${r.id}`} class:list={rowClass}>
                    <span>
                      <span class="text-foreground font-medium">{r.month}</span>
                      <span class="text-muted-foreground ml-2">{r.project_name}</span>
                    </span>
                    <span class="text-muted-foreground">{new Date(r.created_at).toLocaleDateString()}</span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </section>
      </div>
    )
  }
</AppShell>
