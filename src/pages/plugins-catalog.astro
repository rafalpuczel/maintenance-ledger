---
import AppShell from "@/layouts/AppShell.astro";
import Banner from "@/components/ui/Banner.astro";
import PluginCatalog from "@/components/plugins-catalog/PluginCatalog";
import { createSupabaseClient } from "@/lib/supabase";
import { listCatalog } from "@/lib/plugins-catalog/queries";

const entries = await listCatalog(createSupabaseClient());

const error = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");
const okMessage =
  ok === "created"
    ? "Plugin added."
    : ok === "updated"
      ? "Changes saved."
      : ok === "deleted"
        ? "Plugin removed."
        : null;
---

<AppShell title="Plugins catalog">
  <div class="mx-auto max-w-2xl">
    <div class="mb-6">
      <h1 class="text-2xl font-bold tracking-tight">Plugins catalog</h1>
      <p class="text-muted-foreground mt-1 text-sm">
        The canonical list of plugin names used across reports. Add the plugins you maintain so they’re available as
        dropdown options.
      </p>
    </div>

    {okMessage && <Banner variant="success" message={okMessage} />}

    <PluginCatalog
      entries={entries.map((e) => ({ id: e.id, name: e.name, notes: e.notes }))}
      serverError={error}
      client:load
    />
  </div>
</AppShell>
