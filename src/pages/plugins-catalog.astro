---
import Layout from "@/layouts/Layout.astro";
import PluginCatalog from "@/components/plugins-catalog/PluginCatalog";
import { createSupabaseClient } from "@/lib/supabase";
import { listCatalog } from "@/lib/plugins-catalog/queries";

const entries = await listCatalog(createSupabaseClient());

const error = Astro.url.searchParams.get("error");
const ok = Astro.url.searchParams.get("ok");
const okMessage =
  ok === "created"
    ? "Plugin added."
    : ok === "updated"
      ? "Changes saved."
      : ok === "deleted"
        ? "Plugin removed."
        : null;
---

<Layout title="Plugins catalog">
  <div class="bg-cosmic min-h-screen p-6 text-white">
    <div class="mx-auto max-w-2xl">
      <div class="mb-6 flex items-center justify-between">
        <a href="/" class="text-sm text-blue-100/60 underline-offset-4 hover:underline">← Home</a>
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-xl font-bold text-transparent">
          Plugins catalog
        </h1>
      </div>

      {
        okMessage && (
          <p class="mb-4 rounded-lg border border-emerald-500/30 bg-emerald-900/30 px-3 py-2 text-sm text-emerald-200">
            {okMessage}
          </p>
        )
      }

      <p class="mb-4 text-sm text-blue-100/60">
        The canonical list of plugin names used across reports. Add the plugins you maintain so they’re available as
        dropdown options.
      </p>

      <PluginCatalog
        entries={entries.map((e) => ({ id: e.id, name: e.name, notes: e.notes }))}
        serverError={error}
        client:load
      />
    </div>
  </div>
</Layout>
