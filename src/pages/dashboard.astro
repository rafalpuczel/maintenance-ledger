---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Dashboard">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="rounded-2xl border border-white/10 bg-white/10 p-8 text-center text-white backdrop-blur-xl">
      <h1 class="mb-4 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
        Dashboard
      </h1>
      <p class="text-blue-100/80">Welcome back</p>
      <p class="mt-2 text-sm text-blue-100/50">This page is only for authenticated users.</p>
      <a
        href="/projects"
        class="mt-6 inline-block rounded-lg bg-purple-600 px-4 py-2 text-sm font-medium transition-colors hover:bg-purple-500"
      >
        Projects
      </a>

      <div class="mt-8 border-t border-white/10 pt-6 text-left">
        <p class="mb-3 text-xs font-semibold tracking-wide text-blue-100/50 uppercase">Settings</p>
        <div class="flex flex-col gap-2">
          <a
            href="/brand-settings"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Brand settings
          </a>
          <a
            href="/plugins-catalog"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            Plugins catalog
          </a>
          <a
            href="/pm-contacts"
            class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
          >
            PM contacts
          </a>
        </div>
      </div>

      <form method="POST" action="/api/auth/logout" class="mt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm transition-colors hover:bg-white/20"
        >
          Sign out
        </button>
      </form>
    </div>
  </div>
</Layout>
